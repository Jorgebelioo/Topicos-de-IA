import random
import time

def solucionInicial(n=8):
    tablero = list(range(1, n + 1))
    random.shuffle(tablero)
    return tablero

def funcionObjetivo(tablero):
    c = 0
    n = len(tablero)

    for i in range(n):
        for j in range(i + 1, n):
            if abs(tablero[i] - tablero[j]) == abs(i - j):
                c += 1
    return c

def vecinos(tablero, cantidad):
    lista = []
    n = len(tablero)

    for _ in range(cantidad):
        nuevo = tablero.copy()
        i, j = random.sample(range(n), 2)
        nuevo[i], nuevo[j] = nuevo[j], nuevo[i]
        lista.append(nuevo)

    return lista

