def tabu(iteraciones=5000, limitetabu=50, n_vecinos=30):
    actual = solucionInicial()
    mejor = actual
    mejor_costo = funcionObjetivo(actual)

    lista_tabu = []
    movimientos = 0
    inicio = time.time()

    for _ in range(iteraciones):
        lista_vecinos = vecinos(actual, n_vecinos)

        #mostrar_vecinos(lista_vecinos)

        lista_vecinos.sort(key=lambda x: funcionObjetivo(x))

        for v in lista_vecinos:
            if tuple(v) not in lista_tabu:
                actual = v
                lista_tabu.append(tuple(v))
                movimientos += 1

                c = funcionObjetivo(v)
                if c < mejor_costo:
                    mejor = v
                    mejor_costo = c
                break

        if len(lista_tabu) > limitetabu:
            lista_tabu.pop(0)

        if mejor_costo == 0:
            break

    fin = time.time()
    return mejor, mejor_costo, movimientos, fin - inicio

sol, cost, mov, t = tabu()
print("\nSolución:", sol)
print("Conflictos:", cost)
print("Movimientos:", mov)
print("Tiempo:", round(t, 4), "s")
